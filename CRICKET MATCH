n=int(input("Enter the number of TEAMS: "))
l=[]
for i in range(n):
    teams=input("Enter the team names:")
    l.append(teams)

m=[]

for i in range (n-1):
    for j in range(i+1,n):
        m.append([l[i],l[j]])
print(m)    

pos=1
for i in m:
    print("{}. {} vs {}".format(pos,i[0],i[1]))
    pos=pos+1
