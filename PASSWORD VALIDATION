password=input("Enter the password:")
up=0
lo=0
sp=0
dg=0
if len(password)>7:
    for i in password:
        if i.isupper():
            up=up+1
        elif i.islower():
            lo=lo+1
        elif i.isdigit():
            dg=dg+1
        else:
            sp=sp+1
            
    if (up>0 and lo>0 and sp>0 and dg>0):
        print("Password is strong and valid")
    else:
        print("Please enter a strong password")
        
else:
    print("Password should have minimum of 8 characters!")
    
