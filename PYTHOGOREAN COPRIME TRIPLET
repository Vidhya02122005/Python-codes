def cop(a,b):
    return gcd(a,b)==1
    
def gcd(a,b):
    while (b!=0):
        rem=a%b
        temp=b
        b=rem
        a=temp
    return a

n=int(input("Enter the range :"))
for a in range(5,n):
    for b in range(4,a):
        for c in range(3,b):
            if (b*b + c*c == a*a and cop(a,b) and cop(a,c) and cop(b,c)):
                print(b,c,a)
