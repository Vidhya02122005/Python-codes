class Node:
    def __init__(self,data):
        self.data=data
        self.next=None
        
class Linkedlist:
    def __init__(self):
        self.head=None
    def insert(self,data):
        newnode=Node(data)
        if (self.head==None):
            self.head=newnode
        else:
            temp=self.head
            while(temp.next!=None):
                temp=temp.next
            temp.next=newnode
    def display(self):
        current=self.head
        while (current!=None):
            print(current.data,"--->",end="")
            current=current.next
        
x=Linkedlist()
x.insert(10)
x.insert(20)
x.insert(30)
x.insert(40)
x.display()
